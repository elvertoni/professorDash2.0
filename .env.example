# ProfessorDash — variáveis de ambiente (copie para .env e preencha)

DEBUG=True
SECRET_KEY=troque-por-uma-chave-secreta
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# PostgreSQL
DATABASE_URL=postgres://professordash:professordash@localhost:5432/professordash

# Email (recuperação de senha / notificações)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@prof.tonicoimbra.com

# Caminho do acervo para o command import_acervo (dev local)
ACERVO_PATH=../PROF-TONI

