# ProfessorDash — variáveis de ambiente (copie para .env e preencha)

DEBUG=True
SECRET_KEY=troque-por-uma-chave-secreta
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# PostgreSQL
DATABASE_URL=postgres://professordash:professordash@localhost:5432/professordash

# Email (recuperação de senha / notificações)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@prof.tonicoimbra.com

# Caminho do acervo para o command import_acervo (dev local)
ACERVO_PATH=../PROF-TONI

# --- PRODUÇÃO (Easypanel / VPS) ---
# Defina estas variáveis no painel do App service no Easypanel (Environment).
# NÃO comitar valores reais — este arquivo é só exemplo.
#
# DEBUG=False
# SECRET_KEY=<gerar: python -c "import secrets; print(secrets.token_urlsafe(64))">
# ALLOWED_HOSTS=prof.tonicoimbra.com
# CSRF_TRUSTED_ORIGINS=https://prof.tonicoimbra.com
# PRODUCTION_SECURITY=True
#
# Postgres gerenciado do Easypanel. O host é o NOME do service de banco no
# mesmo projeto (ex.: 'professordash_db'). Pegue user/senha/db no painel.
# DATABASE_URL=postgres://USER:SENHA@professordash_db:5432/professordash
#
# Superuser criado automaticamente no 1º boot (idempotente — ver entrypoint).
# DJANGO_SUPERUSER_EMAIL=admin@prof.tonicoimbra.com
# DJANGO_SUPERUSER_PASSWORD=<senha-forte>
# DJANGO_SUPERUSER_NOME_COMPLETO=Toni Coimbra
